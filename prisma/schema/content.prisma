model Content {
    id            String      @id @default(uuid())
    title         String
    description   String?
    videoUrl      String?
    videoSource   VideoSource @default(NATIVE)
    isFreePreview Boolean     @default(false) // Course preview
    order         Int
    milestoneId   String
    milestone     Milestone   @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
}
